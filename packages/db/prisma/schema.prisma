// packages/db/prisma/schema.prisma
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ───────────────────────────────────────────────
model User {
  id         String   @id @default(cuid())
  clerkId    String   @unique
  email      String   @unique
  name       String?
  role       UserRole @default(STAFF)
  merchantId String?
  merchant   Merchant? @relation(fields: [merchantId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([merchantId])
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
}

// ─── MERCHANT ───────────────────────────────────────────
model Merchant {
  id                    String         @id @default(cuid())
  name                  String
  legalName             String
  taxId                 String         // Steuernummer
  vatId                 String?        // USt-IdNr
  stripeAccountId       String?        @unique
  paypalMerchantId      String?
  fiskalyOrganizationId String?
  status                MerchantStatus @default(ACTIVE)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  users      User[]
  locations  Location[]
  products       Product[]
  categories     Category[]
  taxRates       TaxRate[]
  modifierGroups ModifierGroup[]
  orders         Order[]
  discounts      Discount[]
  payouts    Payout[]
  auditLogs  AuditLog[]
}

enum MerchantStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

// ─── LOCATIONS & DEVICES ────────────────────────────────
model Location {
  id               String   @id @default(cuid())
  merchantId       String
  merchant         Merchant @relation(fields: [merchantId], references: [id])
  name             String
  address          String?
  city             String   @default("Berlin")
  timezone         String   @default("Europe/Berlin")
  currency         String   @default("EUR")
  stripeLocationId String?  @unique
  fiskalyTssId     String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  devices Device[]
  orders  Order[]

  @@index([merchantId])
}

model Device {
  id               String       @id @default(cuid())
  locationId       String
  location         Location     @relation(fields: [locationId], references: [id])
  label            String
  stripeReaderId   String?      @unique
  fiskalyClientId  String?
  serialNumber     String?
  type             DeviceType
  status           DeviceStatus @default(OFFLINE)
  lastSeenAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  orders Order[]

  @@index([locationId])
}

enum DeviceType {
  POS_TABLET
  CARD_READER
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  PAIRING
}

// ─── MENU ───────────────────────────────────────────────
model Category {
  id         String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  name       String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  products Product[]

  @@index([merchantId])
}

model TaxRate {
  id         String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  name       String   // "MwSt. 7%"
  rate       Decimal  @db.Decimal(5, 4) // 0.0700
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  products   Product[]
  orderItems OrderItem[]
}

model Product {
  id          String    @id @default(cuid())
  merchantId  String
  merchant    Merchant  @relation(fields: [merchantId], references: [id])
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  taxRateId   String
  taxRate     TaxRate   @relation(fields: [taxRateId], references: [id])
  name        String
  description String?
  priceCents  Int       // Always store in cents
  emoji       String    @default("🍔")
  sku         String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orderItems      OrderItem[]
  modifierGroups  ProductModifierGroup[]

  @@index([merchantId])
  @@index([categoryId])
}

// ─── MODIFIERS ──────────────────────────────────────────
model ModifierGroup {
  id            String   @id @default(cuid())
  merchantId    String
  merchant      Merchant @relation(fields: [merchantId], references: [id])
  name          String   // "Size", "Extras", "Remove"
  minSelections Int      @default(0)
  maxSelections Int      @default(1) // 0 = unlimited
  isRequired    Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  modifiers Modifier[]
  products  ProductModifierGroup[]

  @@index([merchantId])
}

model Modifier {
  id              String        @id @default(cuid())
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  name            String
  priceCents      Int           @default(0)
  sortOrder       Int           @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  orderItemModifiers OrderItemModifier[]

  @@index([modifierGroupId])
}

model ProductModifierGroup {
  productId       String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([productId, modifierGroupId])
}

// ─── DISCOUNTS ──────────────────────────────────────────
enum DiscountType {
  PERCENT
  FIXED
}

model Discount {
  id         String       @id @default(cuid())
  merchantId String
  merchant   Merchant     @relation(fields: [merchantId], references: [id])
  name       String
  type       DiscountType
  value      Int          // PERCENT: basis points (1000 = 10%), FIXED: cents
  isActive   Boolean      @default(true)
  sortOrder  Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  orders Order[]

  @@index([merchantId])
}

// ─── ORDERS ─────────────────────────────────────────────
model Order {
  id            String       @id @default(cuid())
  orderNumber   String       @unique // ORD-2024-00142
  clientOrderId String?      @unique // Idempotency key from offline POS queue
  merchantId    String
  merchant      Merchant     @relation(fields: [merchantId], references: [id])
  locationId    String
  location      Location     @relation(fields: [locationId], references: [id])
  deviceId      String?
  device        Device?      @relation(fields: [deviceId], references: [id])
  status        OrderStatus  @default(PENDING)
  channel       OrderChannel @default(POS)
  subtotalCents Int
  taxCents      Int
  totalCents    Int
  discountId    String?
  discount      Discount?    @relation(fields: [discountId], references: [id])
  discountName  String?
  discountType  DiscountType?
  discountCents Int          @default(0)
  currency      String       @default("EUR")
  customerEmail String?
  customerNote  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  completedAt   DateTime?

  items             OrderItem[]
  payments          Payment[]
  refunds           Refund[]
  receipt           Receipt?
  fiscalTransaction FiscalTransaction?
  qrPaymentLink     QrPaymentLink?

  @@index([merchantId])
  @@index([locationId])
  @@index([status])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  CANCELLED
  FAILED
}

enum OrderChannel {
  POS
  QR
  KIOSK
}

model OrderItem {
  id               String  @id @default(cuid())
  orderId          String
  order            Order   @relation(fields: [orderId], references: [id])
  productId        String?
  product          Product? @relation(fields: [productId], references: [id])
  taxRateId        String
  taxRate          TaxRate  @relation(fields: [taxRateId], references: [id])
  name             String  // Snapshot
  priceCents       Int
  quantity         Int
  subtotalCents    Int
  taxCents         Int
  totalCents       Int
  taxRateSnapshot  Decimal @db.Decimal(5, 4)

  modifiers OrderItemModifier[]

  @@index([orderId])
}

model OrderItemModifier {
  id          String    @id @default(cuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierId  String?
  modifier    Modifier? @relation(fields: [modifierId], references: [id])
  name        String
  priceCents  Int       @default(0)

  @@index([orderItemId])
}

// ─── PAYMENTS ───────────────────────────────────────────
model Payment {
  id                String        @id @default(cuid())
  orderId           String
  order             Order         @relation(fields: [orderId], references: [id])
  provider          PaymentProvider
  providerPaymentId String?       @unique
  providerChargeId  String?
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  amountCents       Int
  currency          String        @default("EUR")
  stripeReaderId    String?
  failureCode       String?
  failureMessage    String?
  idempotencyKey    String        @unique
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  refunds Refund[]

  @@index([orderId])
  @@index([providerPaymentId])
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  CASH
}

enum PaymentMethod {
  CARD_PRESENT
  CONTACTLESS
  APPLE_PAY
  GOOGLE_PAY
  PAYPAL_QR
  CASH
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  REQUIRES_ACTION
}

// ─── REFUNDS ────────────────────────────────────────────
model Refund {
  id               String       @id @default(cuid())
  orderId          String
  order            Order        @relation(fields: [orderId], references: [id])
  paymentId        String
  payment          Payment      @relation(fields: [paymentId], references: [id])
  providerRefundId String?      @unique
  amountCents      Int
  reason           String?
  status           RefundStatus @default(PENDING)
  initiatedBy      String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([orderId])
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
}

// ─── RECEIPTS ───────────────────────────────────────────
model Receipt {
  id              String   @id @default(cuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])
  receiptNumber   String   @unique
  pdfUrl          String?
  emailSentTo     String?
  qrCodeUrl       String?
  merchantName    String
  merchantAddress String
  merchantTaxId   String
  vatBreakdown    Json     // [{rate, net, vat, gross}]
  issuedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
}

// ─── PAYOUTS ────────────────────────────────────────────
model Payout {
  id               String       @id @default(cuid())
  merchantId       String
  merchant         Merchant     @relation(fields: [merchantId], references: [id])
  providerPayoutId String?      @unique
  amountCents      Int
  currency         String       @default("EUR")
  status           PayoutStatus @default(PENDING)
  arrivalDate      DateTime?
  description      String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([merchantId])
}

enum PayoutStatus {
  PENDING
  IN_TRANSIT
  PAID
  FAILED
  CANCELLED
}

// ─── FISCALIZATION ──────────────────────────────────────
model FiscalTransaction {
  id                 String   @id @default(cuid())
  orderId            String   @unique
  order              Order    @relation(fields: [orderId], references: [id])
  fiskalyTxId        String?  @unique
  fiskalyTssId       String
  fiskalyClientId    String
  transactionType    String   @default("RECEIPT")
  signature          String?
  signatureCounter   Int?
  processType        String?  @default("Kassenbeleg-V1")
  processData        String?
  startTime          DateTime
  endTime            DateTime?
  exportedToDsfinvk  Boolean  @default(false)
  createdAt          DateTime @default(now())

  @@index([fiskalyTssId])
}

// ─── QR PAYMENT LINKS ───────────────────────────────────
model QrPaymentLink {
  id          String       @id @default(cuid())
  orderId     String       @unique
  order       Order        @relation(fields: [orderId], references: [id])
  token       String       @unique @default(cuid())
  status      QrLinkStatus @default(ACTIVE)
  expiresAt   DateTime
  scannedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  @@index([token])
}

enum QrLinkStatus {
  ACTIVE
  SCANNED
  COMPLETED
  EXPIRED
  CANCELLED
}

// ─── AUDIT LOG (GoBD — immutable) ───────────────────────
model AuditLog {
  id         String    @id @default(cuid())
  merchantId String?
  merchant   Merchant? @relation(fields: [merchantId], references: [id])
  userId     String?
  action     String    // "order.created"
  entityType String    // "Order"
  entityId   String
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  // GoBD: NEVER update or delete audit log rows — enforce at app layer
  @@index([merchantId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
