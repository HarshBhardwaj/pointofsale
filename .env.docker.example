# Copy to .env in the project root before running: cp .env.docker.example .env

# ─── Postgres ─────────────────────────────────────────────
POSTGRES_USER=truckpos
POSTGRES_PASSWORD=change-me
POSTGRES_DB=truckpos

# ─── Ports (host machine) ─────────────────────────────────
WEB_PORT=3000
API_PORT=3001

# ─── Public URLs (use your server IP or domain) ───────────
# Browser-facing web app URL (for API CORS)
FRONTEND_URL=http://YOUR_SERVER_IP:3000
# Public API URL baked into the Next.js build (must match how browsers reach the API)
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:3001
API_URL=http://YOUR_SERVER_IP:3001

# Set true on first deploy to load demo products/locations
RUN_DB_SEED=true

# ─── Clerk (required — copy real values from https://dashboard.clerk.com) ─
# Do NOT use placeholder text like pk_test_... ; paste your full key from the dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_FULL_KEY_FROM_CLERK_DASHBOARD
CLERK_SECRET_KEY=sk_test_REPLACE_WITH_FULL_KEY_FROM_CLERK_DASHBOARD
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_FULL_KEY_FROM_CLERK_DASHBOARD
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/pos
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/pos

# ─── Stripe ───────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── PayPal ─────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# ─── fiskaly (German TSE) ───────────────────────────────────
FISKALY_API_KEY=
FISKALY_API_SECRET=
FISKALY_BASE_URL=https://kassensichv-middleware.fiskaly.com/api/v2
